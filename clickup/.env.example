# ClickUp local integration — copy this file to `.env` and fill in real values.
# `.env` is gitignored (root .gitignore: .env / .env.*) so the token never enters git.
# The token powers BOTH ./cu.sh (direct API, preferred) and the local MCP server.

# Personal API token. ClickUp → Settings → Apps → "API Token" → Generate.
# Starts with "pk_". This is YOUR access key (not the global claude.ai connector).
CLICKUP_API_KEY=pk_XXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Workspace (a.k.a. "team") ID. It's the number right after the domain in the URL
# when you're in ClickUp: https://app.clickup.com/<CLICKUP_TEAM_ID>/v/...
CLICKUP_TEAM_ID=1234567

# Enable the MCP server's ClickUp Docs tools (cu.sh has its own docs support regardless).
DOCUMENT_SUPPORT=true

# --- Optional tuning (safe to leave commented) ---
# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info
